<%- include('partials/header') %>
<main>
  <section class="page-hero page-hero--sm">
    <div class="container">
      <h1 class="page-title">My Profile</h1>
    </div>
  </section>
  <section class="section">
    <div class="container container--narrow">
      <div class="form-card" style="margin-bottom:24px">
        <div style="display:flex;align-items:center;gap:20px;margin-bottom:28px">
          <div class="user-avatar-lg" style="width:72px;height:72px;font-size:2rem">
            <% if (user.avatar) { %><img src="<%= user.avatar %>" /><% } else { %><%= user.name.charAt(0) %><% } %>
          </div>
          <div>
            <h2 style="font-family:var(--font-display);font-size:1.6rem;font-weight:400"><%= user.name %></h2>
            <p style="color:var(--text-muted);font-size:0.85rem"><%= user.email %></p>
          </div>
        </div>
        <div id="profileError"   class="alert alert--error"   style="display:none"></div>
        <div id="profileSuccess" class="alert alert--success" style="display:none"></div>
        <div class="form-group">
          <label class="form-label">Full Name</label>
          <input type="text" id="profName" class="form-input" value="<%= user.name %>" />
        </div>
        <div class="form-group">
          <label class="form-label">Bio</label>
          <textarea id="profBio" class="form-textarea" rows="3" maxlength="300"><%= user.bio || '' %></textarea>
        </div>
        <div class="form-group">
          <label class="form-label">Location</label>
          <input type="text" id="profLocation" class="form-input" value="<%= user.location || '' %>" placeholder="City, Country" />
        </div>
        <div class="form-group">
          <label class="form-label">Avatar URL</label>
          <input type="url" id="profAvatar" class="form-input" value="<%= user.avatar || '' %>" placeholder="https://..." />
        </div>
        <div class="form-actions">
          <button id="saveProfile" class="btn-primary">Save Changes</button>
        </div>
      </div>

      <!-- My Events Summary -->
      <div class="form-card">
        <div class="section-header section-header--sm">
          <h3 style="font-family:var(--font-display);font-size:1.3rem;font-weight:400">My Events (<%= myEvents.length %>)</h3>
          <a href="/events/new" class="link-arrow">Create new →</a>
        </div>
        <% if (myEvents.length === 0) { %>
          <div class="empty-state"><p>No events yet. <a href="/events/new">Create your first</a></p></div>
        <% } else { %>
          <div class="list-events">
            <% myEvents.forEach(event => { %>
              <div class="list-event-item">
                <div class="list-event-info">
                  <span class="list-event-status list-event-status--<%= event.status %>"><%= event.status %></span>
                  <a href="/events/<%= event._id %>" class="list-event-title"><%= event.title %></a>
                  <span class="list-event-date"><%= new Date(event.date).toLocaleDateString() %></span>
                </div>
                <a href="/events/<%= event._id %>/edit" class="btn-icon">✎</a>
              </div>
            <% }) %>
          </div>
        <% } %>
      </div>
    </div>
  </section>
</main>
<%- include('partials/footer') %>
<script>
document.getElementById('saveProfile').addEventListener('click', async () => {
  const payload = {
    name:     document.getElementById('profName').value.trim(),
    bio:      document.getElementById('profBio').value.trim(),
    location: document.getElementById('profLocation').value.trim(),
    avatar:   document.getElementById('profAvatar').value.trim(),
  };
  const res  = await fetch('/auth/profile', { method:'PUT', headers:{'Content-Type':'application/json'}, body:JSON.stringify(payload) });
  const data = await res.json();
  const err  = document.getElementById('profileError');
  const ok   = document.getElementById('profileSuccess');
  if (data.success) {
    ok.textContent = 'Profile updated!'; ok.style.display = 'block'; err.style.display = 'none';
    setTimeout(() => ok.style.display = 'none', 3000);
  } else {
    err.textContent = data.message; err.style.display = 'block'; ok.style.display = 'none';
  }
});
</script>