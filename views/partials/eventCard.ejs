<article class="event-card" data-id="<%= event._id %>">
  <a href="/events/<%= event._id %>" class="card-image-wrap">
    <% if (event.coverImage) { %>
      <img src="<%= event.coverImage %>" alt="<%= event.title %>" class="card-image" loading="lazy" />
    <% } else { %>
      <div class="card-image-placeholder">
        <span class="cat-badge cat-badge--<%= event.category.toLowerCase() %>"><%= event.category %></span>
      </div>
    <% } %>
    <span class="card-status card-status--<%= event.status %>"><%= event.status %></span>
  </a>
  <div class="card-body">
    <div class="card-meta">
      <span class="card-date">
        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/>
          <line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
        </svg>
        <%= new Date(event.date).toLocaleDateString('en-US', { month:'short', day:'numeric', year:'numeric' }) %>
      </span>
      <span class="card-attendees">
        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
          <circle cx="9" cy="7" r="4"/>
          <path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/>
        </svg>
        <%= event.attendeeCount || event.attendees.length %> going
      </span>
    </div>
    <h3 class="card-title"><a href="/events/<%= event._id %>"><%= event.title %></a></h3>
    <p class="card-location">
      <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
        <circle cx="12" cy="10" r="3"/>
      </svg>
      <%= event.location.name %>
    </p>
    <div class="card-organizer">
      <div class="organizer-avatar">
        <% if (event.organizer && event.organizer.avatar) { %>
          <img src="<%= event.organizer.avatar %>" alt="<%= event.organizer.name %>" />
        <% } else if (event.organizer) { %>
          <%= event.organizer.name.charAt(0).toUpperCase() %>
        <% } %>
      </div>
      <span>by <%= event.organizer ? event.organizer.name : 'Unknown' %></span>
    </div>
  </div>
</article>