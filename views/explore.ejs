<%- include('partials/header') %>

<main>
  <section class="page-hero page-hero--sm">
    <div class="container">
      <h1 class="page-title">Explore Events</h1>
      <p class="page-sub">Discover what's happening near you</p>
    </div>
  </section>

  <section class="section">
    <div class="container">

      <!-- Filters -->
      <div class="filters-bar">
        <form action="/explore" method="GET" class="filters-form" id="filtersForm">
          <div class="search-field">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
            </svg>
            <input type="text" name="search" value="<%= search %>" placeholder="Search events..." class="input-search" />
          </div>
          <div class="category-pills">
            <% categories.forEach(cat => { %>
              <button type="submit" name="category" value="<%= cat %>"
                class="pill <%= category === cat ? 'pill--active' : '' %>"><%= cat %></button>
            <% }) %>
          </div>
        </form>
      </div>

      <!-- Results -->
      <div class="results-meta">
        <span><strong><%= total %></strong> event<%= total !== 1 ? 's' : '' %> found</span>
        <% if (search || category !== 'All') { %>
          <a href="/explore" class="link-clear">Clear filters ×</a>
        <% } %>
      </div>

      <% if (events.length === 0) { %>
        <div class="empty-state empty-state--large">
          <svg viewBox="0 0 80 80" width="80" height="80" fill="none" stroke="currentColor" stroke-width="1">
            <circle cx="40" cy="40" r="35"/><path d="M40 20v20l12 12"/>
          </svg>
          <h3>No events found</h3>
          <p>Try a different search or <a href="/events/new">create the first one</a>.</p>
        </div>
      <% } else { %>
        <div class="events-grid events-grid--3">
          <% events.forEach(event => { %>
            <%- include('partials/eventCard', { event }) %>
          <% }) %>
        </div>
      <% } %>

      <!-- Pagination -->
      <% if (totalPages > 1) { %>
        <div class="pagination">
          <% if (page > 1) { %>
            <a href="/explore?page=<%= page-1 %>&category=<%= category %>&search=<%= search %>" class="page-btn">← Prev</a>
          <% } %>
          <% for(let i = 1; i <= totalPages; i++) { %>
            <a href="/explore?page=<%= i %>&category=<%= category %>&search=<%= search %>"
               class="page-btn <%= i === page ? 'page-btn--active' : '' %>"><%= i %></a>
          <% } %>
          <% if (page < totalPages) { %>
            <a href="/explore?page=<%= page+1 %>&category=<%= category %>&search=<%= search %>" class="page-btn">Next →</a>
          <% } %>
        </div>
      <% } %>

    </div>
  </section>
</main>

<%- include('partials/footer') %>